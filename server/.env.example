# انسخ هذا الملف إلى .env على الخادم واملأ القيم الحقيقية.
# لا تضف ملف .env نفسه أبداً إلى Git (تأكد أنه مذكور في .gitignore).

# اتصال قاعدة بيانات PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname
# اجعلها false فقط لو تشغّل Postgres محلياً بدون SSL
DATABASE_SSL=true

# سر توقيع جلسات الدخول (JWT) — استخدم نصاً عشوائياً طويلاً وفريداً
JWT_SECRET=ASDASHDKJHASDKJHFASJDHFASDFASHDFKAHSFDJHASFDJASDASDSADASDASDASDASDSADASDASDASDHFSAJHK

# سر توليد/التحقق من أكواد ترخيص البرنامج — يجب أن يطابق تماماً القيمة
# المستخدمة في أداة توليد أكواد الترخيص الخاصة بك (المنفصلة عن هذا المستودع).
# ⚠️ ضع هنا قيمة عشوائية طويلة خاصة بك فقط — لا تستخدم أي قيمة سبق ذكرها
# في أي نسخة قديمة من هذا الملف أو من app-inline.js، فهي تُعتبر مكشوفة نهائياً.
LICENSE_SECRET=REPLACE_WITH_YOUR_OWN_LONG_RANDOM_SECRET

# مفتاح Anthropic API (لقراءة فواتير الدورات بالذكاء الاصطناعي من صور/PDF)
ANTHROPIC_API_KEY=sk-ant-...

# منفذ تشغيل الخادم (اختياري، افتراضي 3000)
PORT=3000

# الأصول (origins) المسموح لها بمناداة الـ API من متصفح مختلف عن دومين الخادم نفسه،
# مفصولة بفواصل (مثال: https://app.example.com,https://admin.example.com).
# اتركه فارغاً إن كانت الواجهة تُخدَّم دائماً من نفس دومين هذا الخادم (الوضع الافتراضي والموصى به).
CORS_ORIGIN=
